91541cce1ed4\>\"", "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"form", "=", 
    RowBox[{"FormFunction", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<Name\>\"", "->", 
         RowBox[{"<|", 
          RowBox[{"\"\<Label\>\"", "->", "\"\<Name\>\""}], "|>"}]}], ",", 
        RowBox[{"\"\<Affiliation\>\"", "->", 
         RowBox[{"<|", 
          
          RowBox[{"\"\<Label\>\"", 
           "->", "\"\<Institutional Affiliation\>\""}], "|>"}]}], ",", 
        RowBox[{"\"\<Sector\>\"", "->", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<Label\>\"", "->", "\"\<Sector\>\""}], ",", 
           RowBox[{"\"\<Interpreter\>\"", "->", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Academia\>\"", ",", "\"\<Industry\>\"", 
              ",", "\"\<Independent / Other\>\""}], "}"}]}], ",", 
           
           RowBox[{"\"\<Help\>\"", 
            "->", "\"\<We aim to create a balanced dialogue between research \
environments.\>\""}]}], "|>"}]}], ",", 
        RowBox[{"\"\<Topic\>\"", "->", 
         RowBox[{"<|", 
          RowBox[{"\"\<Label\>\"", "->", "\"\<Talk Title\>\""}], "|>"}]}], ",", 
        RowBox[{"\"\<Abstract\>\"", "->", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<Label\>\"", "->", "\"\<Abstract / Pitch\>\""}], ",", 
           RowBox[{"\"\<Interpreter\>\"", "->", "\"\<String\>\""}], ",", 
           RowBox[{"\"\<Help\>\"", "->", "\"\<(max 300 words).\>\""}]}], 
          "|>"}]}], ",", 
        RowBox[{"\"\<Duration\>\"", "->", 
         RowBox[{"<|", 
          RowBox[{
           
           RowBox[{"\"\<Label\>\"", 
            "->", "\"\<Maximum Preferred Duration\>\""}], ",", 
           RowBox[{"\"\<Interpreter\>\"", "->", 
            RowBox[{"{", 
             
             RowBox[{"\"\<15 minutes\>\"", ",", "\"\<30 minutes\>\"", 
              ",", "\"\<45 minutes\>\""}], "}"}]}], ",", 
           
           RowBox[{"\"\<Help\>\"", 
            "->", "\"\<Please indicate the longest duration you are \
comfortable speaking for. \\nNote: As this is a half-day event, we may \
allocate shorter slots to accommodate the final program schedule.\>\""}]}], 
          "|>"}]}], ",", 
        RowBox[{"\"\<Attendance\>\"", "->", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<Label\>\"", "->", "\"\<Attendance Preference\>\""}], ",", 
           RowBox[{"\"\<Interpreter\>\"", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<In-person\>\"", ",", "\"\<Virtual\>\""}], "}"}]}], ",", 
           
           RowBox[{"\"\<Help\>\"", 
            "->", "\"\<This is a hybrid event. We cannot provide travel \
support for in-person attendees.\>\""}]}], "|>"}]}]}], "}"}], ",", 
      RowBox[{"Function", "[", 
       RowBox[{"params", ",", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "data", "}"}], ",", 
          RowBox[{
           RowBox[{"data", "=", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"FileExistsQ", "[", "submissionFile", "]"}], ",", 
              RowBox[{"CloudGet", "[", "submissionFile", "]"}], ",", 
              RowBox[{"{", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"CloudPut", "[", 
            RowBox[{
             RowBox[{"Append", "[", 
              RowBox[{"data", ",", 
               RowBox[{"Join", "[", 
                RowBox[{"params", ",", 
                 RowBox[{"<|", 
                  RowBox[{"\"\<Timestamp\>\"", "->", "Now"}], "|>"}]}], 
                "]"}]}], "]"}], ",", "submissionFile"}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{"Nicer", " ", "HTML", " ", "Success", " ", "Page"}], 
            "*)"}], 
           
           RowBox[{"\"\<<div>\n      <div style='text-align: center; padding: \
40px 20px; font-family: sans-serif;'>\n        <h2 style='color: #2c3e50; \
margin-bottom: 10px;'>Submission Received</h2>\n        <p style='font-size: \
1.1em; color: #555;'>Thank you, <strong>\>\"", "<>", 
            RowBox[{"params", "[", "\"\<Name\>\"", "]"}], 
            "<>", "\"\<</strong>.</p>\n        <p style='color: #555;'>Your \
proposal has been successfully recorded for Edge Cases 2026.</p>\n        <hr \
style='border: 0; border-top: 1px solid #eee; margin: 30px auto; width: \
50%;'>\n        <p style='font-size: 0.9em;'><a \
href='https://edgecases2026.org/' style='color: #3498db; text-decoration: \
none;'>Return to Edge Cases Website</a></p>\n      </div>\n    \
</div>\>\""}]}]}], 
         RowBox[{"(*", 
          RowBox[{"\"\<Thank you, \>\"", "<>", 
           RowBox[{"params", "[", "\"\<Name\>\"", "]"}], 
           "<>", "\"\<. Your proposal has been received.\>\""}], "*)"}], 
         "]"}]}], "]"}], ",", "\"\<HTML\>\"", ",", 
      RowBox[{"AppearanceRules", "->", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Title\>\"", 
          "->", "\"\<Edge Cases 2026: Call for Speakers\>\""}], ",", 
         RowBox[{"\"\<Description\>\"", "->", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            
            RowBox[{"\"\<We are soliciting submissions for the Edge Cases \
satellite at CCS 2026.\>\"", 
             ",", "\"\<Edge Cases is dedicated to platforming network science \
research in unconventional problem spaces. We are seeking contributions that \
show novel applications of graph theory in non-traditional domains, challenge \
standard modeling paradigms, or connect under-connected fields.\>\""}], "}"}],
            "]"}]}]}], "|>"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\n", 
  RowBox[{"(*", "Deploy", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"CloudDeploy", "[", 
  RowBox[{"form", ",", "\"\<EdgeCases2026_Submission\>\"", ",", 
